export PRJ=$DEV/prj
export DRAFTS=$DEV/drafts
export EDITOR=vim

# OTHER ENVS
export HTTP_SERVERS_FILE=$SEC/http.json

# PATH
export PATH=/usr/local/texlive/2023/bin/x86_64-linux:$PATH
export PATH="/home/yx/.local/bin:$PATH"
export PATH=/home/yx/.cargo/bin:$PATH

# KEYS
source $SEC/API.env

# INCLUDES
source $DRAFTS/sh/include/include

declare -A INCLUDES
INCLUDES[sr]="$DRAFTS/sh/sr/sr"
