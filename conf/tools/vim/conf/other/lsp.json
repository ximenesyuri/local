{  
    "diagnostic.level": "error",
    "diagnostic.refreshOnInsertMode": true,
    "diagnostic.format": "%message",
    "pullDiagnostic.onChange": false,
    "pullDiagnostic.onSave": true,
    "colors.enable": true,
    "suggest.acceptSuggestionOnCommitCharacter": true,
    "suggest.snippetsSupport": true,
    "suggest.removeCurrentWord": true,
    "suggest.triggerCompletionWait": 10,
    "suggest.preferCompleteThanJumpPlaceholder": true,
    "suggest.defaultSortMethod": "alphabetical",
    "suggest.enableFloat": true,
    "suggest.removeDuplicateItems": true,
    "suggest.languageSourcePriority": 0,
    "python.analysis.logLevel": "Warning",
    "python.linting.enabled": true,
    "pyright.disableDiagnostics": false,
    "python.analysis.diagnosticMode": "openFilesOnly",
    "python.analysis.diagnosticSeverityOverrides": {
        "reportMissingImports": "error",
        "reportMissingModuleSource": "error",
        "reportImportCycles": "error",
        "reportUnusedImport": "error",
        "reportDuplicateImport": "error",
        "reportUndefinedVariable": "error"
    },
    "python.analysis.typeshedPaths": [".venv/lib/python3.13/site-packages/typed/typed"],
    "python.analysis.typeCheckingMode": "off",
    "python.analysis.autoImportCompletions": true,
    "python.analysis.extraPaths": [".venv/lib/python3.13/site-packages"],
    "pyright.completion.importSupport": true,
    "pyright.disableTaggedHints": true,
    "pyright.inlayHints.variableTypes": false,
    "pyright.inlayHints.functionReturnTypes": false,
    "pyright.inlayHints.parameterTypes": false,
    "html.suggest.html5": true,
    "html.filetypes": ["html", "jinja"],
    "html.validate.scripts": true,
    "html.autoClosingTags": false,
    "html.autoCreateQuotes": true,
    "html.format.enable": true,
    "html.hover.documentation": true,
    "html.hover.references": true,
    "snippets.ultisnips.directories": [          
        "UltiSnips",
        "/home/yx/conf/vim/snippets"
    ],
    "snippets.ultisnips.pythonPrompt": false,
    "markdown-preview-enhanced.previewTheme": "github-dark.css",
    "markdown-preview-enhanced.mathRenderingOption": "KaTeX",
    "markdown-preview-enhanced.mathBlockDelimiters": [[":::tex", ":::"]],
    "markdown-preview-enhanced.mathInlineDelimiters": [[":tex", ":"]]
}

